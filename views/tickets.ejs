 <!DOCTYPE html>
 <html lang="en">
<%- include('layout/head') %>
 <body>
    <%- include('layout/navbar') %>
    <main>
        <div class="tickets-grid">
<% if (ticket_s) { %>
  <% ticket_s.forEach(ticket => { %>
    <div class="ticket-card <%= ticket.isexpired ? 'expired' : '' %>">
      <div class="ticket-header">
        <span class="ticket-id">#<%= ticket.ticket_id.substring(0, 8) %></span>
        <% if (ticket.isexpired) { %>
          <span class="status-badge">Expired</span>
        <% } else { %>
          <span class="status-badge active">Valid</span>
        <% } %>
      </div>

      <div class="ticket-body">
        <div class="info-group">
          <label>Wallet (Phone)</label>
          <p><%= ticket.wallet %></p>
        </div>
        
        <div class="info-group">
          <label>Quantity</label>
          <p><%= ticket.amount %> Tickets</p>
        </div>

        <div class="info-group">
          <label>Total Price</label>
          <p class="price"><%= ticket.price %> ETB</p>
        </div>
      </div>

      <div class="ticket-footer">
        <small>Route ID: <%= ticket.routeid %></small>
      </div>
    </div>
  <% }) %>
  <% } else { %>
    <h3 style="position: absolute;top: 50%;left: 50%;transform: translate(-50%,-50%);"> No ticket bought til now!</h3>
  <% } %>
</div> 
    </main>
 </body>
 </html>